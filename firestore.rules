rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /complaints/{id} {
      allow read, write: if request.auth != null;
    }

    match /users/{id} {
      allow read, write: if request.auth != null;
    }

    match /serviceSectors/{id} {
      allow read, write: if request.auth != null;
    }

    match /notifications/{id} {
      allow read, write: if request.auth != null;
    }

    match /adminSettings/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
